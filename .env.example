PORT=3000
LOG_LEVEL=info

REVERB_API_BASE=https://api.reverb.com/api
REVERB_PERSONAL_TOKEN=PASTE_YOUR_REVERB_PERSONAL_TOKEN_HERE
REVERB_ORDERS_PATH=/my/orders/selling/all
REVERB_LISTINGS_PATH=/my/listings
REVERB_PAGE_SIZE=50

AIRTABLE_PAT=PASTE_YOUR_AIRTABLE_PAT_HERE
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Inventory

AIRTABLE_SKU_FIELD=SKU
AIRTABLE_STATUS_FIELD=Status
AIRTABLE_QTY_FIELD=Qty On Hand
AIRTABLE_PRICE_FIELD=Price
AIRTABLE_CHANNEL_FIELD=Channel
AIRTABLE_LISTED_FIELD=Listed
AIRTABLE_REVERB_LISTING_ID_FIELD=Reverb Listing ID
AIRTABLE_REVERB_ORDER_ID_FIELD=Reverb Order ID
AIRTABLE_REVERB_STATUS_FIELD=Reverb Status
AIRTABLE_LAST_SYNC_SOURCE_FIELD=Last Sync Source
AIRTABLE_LAST_SYNC_AT_FIELD=Last Sync At
AIRTABLE_SOLD_CHANNEL_FIELD=Sold Channel
AIRTABLE_SOLD_DATE_FIELD=Sold Date
AIRTABLE_ATTENTION_FIELD=Needs Attention

CHANNEL_WAREHOUSE=WAREHOUSE
STATUS_LISTED_WAREHOUSE=LISTED - WAREHOUSE
STATUS_NOT_LISTED_WAREHOUSE=NOT LISTED - WAREHOUSE
STATUS_SOLD=SOLD
SOLD_CHANNEL_REVERB_WAREHOUSE=REVERB WAREHOUSE

REVERB_DECREMENT_ORDER_STATUSES=paid,shipped,completed,delivered
